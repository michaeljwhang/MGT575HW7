# Copy to .env and fill in. Used by run_lecture_pipeline.py (load_dotenv).

# --- LLM (pick one provider) ---
PIPELINE_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Or Google for vision/text:
# PIPELINE_LLM_PROVIDER=google
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash

# --- TTS ---
PIPELINE_TTS_PROVIDER=openai
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy

# Or ElevenLabs:
# PIPELINE_TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Or Gemini TTS (also uses GOOGLE_API_KEY):
# PIPELINE_TTS_PROVIDER=gemini
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Kore

# Optional:
# PDF_RASTER_DPI=150
